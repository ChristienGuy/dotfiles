autoload -Uz compinit
compinit

# Enable persistent history
export HISTFILE=~/.zsh_history
export HISTSIZE=100000
export SAVEHIST=100000
setopt APPEND_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt INC_APPEND_HISTORY

# Starship
eval "$(starship init zsh)"

# Antidote
source $(brew --prefix)/opt/antidote/share/antidote/antidote.zsh
antidote load ~/.zsh/.zsh_plugins.txt

# Aliases
source ~/.zsh/.zsh_aliases

# git-spice
eval "$(gs shell completion zsh)"

# Interactive rebase to sign all commits in the named branch
function grb-sign() {
	local branch=$1
	if [ -z "$branch" ]; then
		branch=$(git branch --show-current)
	fi
	git rebase $branch --exec 'git commit --amend --no-edit -n -S'
}

# NVM
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

# PHP (optional; adjust or remove if not using Herd)
export PHP_INI_SCAN_DIR="${HOME}/.config/herd-lite/bin:${PHP_INI_SCAN_DIR}"

# PYENV
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
# Optional: pin a specific Python version on PATH (edit or remove if not needed)
[[ -d "$PYENV_ROOT/versions/2.7.18/bin" ]] && PATH="$PYENV_ROOT/versions/2.7.18/bin:$PATH"

# Substring history search 
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
